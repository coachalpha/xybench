# Slack notification (optional)
XYBENCH_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Email notification (optional)
XYBENCH_SMTP_HOST=smtp.gmail.com
XYBENCH_SMTP_PORT=587
XYBENCH_SMTP_USER=you@example.com
XYBENCH_SMTP_PASSWORD=your-app-password
XYBENCH_SMTP_FROM=you@example.com

# Storage path (default: ./reviews)
XYBENCH_STORAGE_DIR=./reviews
